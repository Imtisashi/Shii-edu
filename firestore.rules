rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function profileExists() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return profileExists() ? profile().role : null;
    }

    function isSuperAdminRole(value) {
      return value in ['superadmin', 'superAdmin', 'SuperAdmin', 'super_admin', 'super-admin', 'super admin'];
    }

    function isSuperAdmin() {
      return signedIn() && (
        isSuperAdminRole(role()) ||
        isSuperAdminRole(request.auth.token.role) ||
        isSuperAdminRole(request.auth.token.userRole) ||
        isSuperAdminRole(request.auth.token.user_role) ||
        request.auth.token.superadmin == true ||
        request.auth.token.superAdmin == true
      );
    }

    function isAdmin() {
      return signedIn() && role() == 'admin';
    }

    function isTeacher() {
      return signedIn() && role() == 'teacher';
    }

    function isProfessor() {
      return signedIn() && role() == 'professor';
    }

    function isFaculty() {
      return isTeacher() || isProfessor();
    }

    function isStudent() {
      return signedIn() && role() == 'student';
    }

    function isParent() {
      return signedIn() && role() == 'parent';
    }

    function isDriver() {
      return signedIn() && role() == 'driver';
    }

    function sameInstituteId(instituteId) {
      return profileExists() &&
        instituteId is string &&
        profile().instituteId == instituteId;
    }

    function sameInstitute(data) {
      return data.keys().hasAny(['instituteId']) &&
        sameInstituteId(data.instituteId);
    }

    function instituteIdUnchanged() {
      return resource.data.keys().hasAny(['instituteId']) &&
        request.resource.data.keys().hasAny(['instituteId']) &&
        request.resource.data.instituteId == resource.data.instituteId;
    }

    function sameInstituteUpdate() {
      return instituteIdUnchanged() &&
        sameInstitute(resource.data) &&
        sameInstitute(request.resource.data);
    }

    function adminOrTeacherFor(instituteId) {
      return (isAdmin() || isFaculty()) && sameInstituteId(instituteId);
    }

    function adminFor(instituteId) {
      return isAdmin() && sameInstituteId(instituteId);
    }

    function readByList(data) {
      return data.keys().hasAny(['readBy']) ? data.readBy : [];
    }

    function notificationReadReceiptOnly() {
      let existingReadBy = readByList(resource.data);
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']) &&
        request.resource.data.readBy is list &&
        request.resource.data.readBy.hasAll(existingReadBy) &&
        request.resource.data.readBy.size() <= existingReadBy.size() + 1 &&
        request.auth.uid in request.resource.data.readBy;
    }

    function immutableUserFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['uid', 'role', 'instituteId', 'createdAt', 'createdBy', 'authEmail']);
    }

    function selfEditableUserFields() {
      return request.auth.uid == resource.data.uid &&
        role() in ['admin', 'teacher', 'professor', 'superadmin'] &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'cloudinaryProfileImage',
          'degree',
          'experience',
          'name',
          'photoURL',
          'profilePic',
          'profileUpdatedAt',
          'updatedAt'
        ]);
    }

    function studentOwnsAttendance(data) {
      return isStudent() && sameInstitute(data) && (
        data.studentId == request.auth.uid ||
        (data.keys().hasAny(['studentUid']) && data.studentUid == request.auth.uid) ||
        (profile().keys().hasAny(['loginId']) && profile().loginId != null && data.studentId == profile().loginId) ||
        (profile().keys().hasAny(['uniqueId']) && profile().uniqueId != null && data.studentId == profile().uniqueId) ||
        (profile().keys().hasAny(['loginId']) && data.keys().hasAny(['studentUniqueId']) && data.studentUniqueId == profile().loginId) ||
        (profile().keys().hasAny(['uniqueId']) && data.keys().hasAny(['studentUniqueId']) && data.studentUniqueId == profile().uniqueId)
      );
    }

    function studentOwnsGrade(data) {
      return isStudent() && sameInstitute(data) && (
        data.studentId == request.auth.uid ||
        (data.keys().hasAny(['studentUid']) && data.studentUid == request.auth.uid) ||
        (profile().keys().hasAny(['loginId']) && profile().loginId != null && data.studentId == profile().loginId) ||
        (profile().keys().hasAny(['uniqueId']) && profile().uniqueId != null && data.studentId == profile().uniqueId) ||
        (profile().keys().hasAny(['loginId']) && data.keys().hasAny(['studentUniqueId']) && data.studentUniqueId == profile().loginId) ||
        (profile().keys().hasAny(['uniqueId']) && data.keys().hasAny(['studentUniqueId']) && data.studentUniqueId == profile().uniqueId)
      );
    }

    function userOwnsInstituteDocument(data) {
      return signedIn() &&
        sameInstitute(data) &&
        data.keys().hasAny(['uid']) &&
        data.uid == request.auth.uid;
    }

    function parentOwnsStudentUid(studentUid) {
      return isParent() &&
        studentUid is string &&
        (
          (profile().keys().hasAny(['linkedStudentUid']) && profile().linkedStudentUid == studentUid) ||
          (profile().keys().hasAny(['childUids']) && profile().childUids is list && studentUid in profile().childUids)
        );
    }

    function parentOwnsStudentData(data) {
      return sameInstitute(data) && (
        (data.keys().hasAny(['studentUid']) && parentOwnsStudentUid(data.studentUid)) ||
        (data.keys().hasAny(['uid']) && parentOwnsStudentUid(data.uid))
      );
    }

    function conversationParticipant(data) {
      return signedIn() &&
        sameInstitute(data) &&
        data.keys().hasAny(['participants']) &&
        data.participants is list &&
        request.auth.uid in data.participants;
    }

    function notificationVisible(data) {
      let targets = data.keys().hasAny(['targetRoles']) ? data.targetRoles : [];
      let recipients = data.keys().hasAny(['recipientUids']) ? data.recipientUids : [];
      return sameInstitute(data) &&
        targets is list &&
        recipients is list &&
        (role() in targets || 'all' in targets) &&
        (
          recipients.size() == 0 ||
          request.auth.uid in recipients ||
          (isParent() && profile().keys().hasAny(['linkedStudentUid']) && profile().linkedStudentUid in recipients)
        );
    }

    match /institutes/{instituteId} {
      allow read: if isSuperAdmin() || sameInstituteId(instituteId);
      allow create, update, delete: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId ||
        isSuperAdmin() ||
        ((isAdmin() || isTeacher()) && sameInstitute(resource.data)) ||
        (isParent() && parentOwnsStudentUid(userId) && sameInstitute(resource.data))
      );

      allow create: if false;

      allow update: if signedIn() && (
        isSuperAdmin() ||
        (request.auth.uid == userId && selfEditableUserFields()) ||
        (adminFor(resource.data.instituteId) && sameInstitute(request.resource.data) && immutableUserFields())
      );

      allow delete: if isSuperAdmin();
    }

    match /notices/{noticeId} {
      allow read: if sameInstitute(resource.data);
      allow create: if isSuperAdmin() || adminOrTeacherFor(request.resource.data.instituteId);
      allow update: if isSuperAdmin() ||
        (adminOrTeacherFor(resource.data.instituteId) && sameInstituteUpdate());
      allow delete: if isSuperAdmin() || adminFor(resource.data.instituteId);
    }

    match /routines/{routineId} {
      allow read: if sameInstitute(resource.data);
      allow create: if isSuperAdmin() || adminFor(request.resource.data.instituteId);
      allow update: if isSuperAdmin() ||
        (adminFor(resource.data.instituteId) && sameInstituteUpdate());
      allow delete: if isSuperAdmin() || adminFor(resource.data.instituteId);
    }

    match /holidays/{holidayId} {
      allow read: if sameInstitute(resource.data);
      allow create: if isSuperAdmin() || adminFor(request.resource.data.instituteId);
      allow update: if isSuperAdmin() ||
        (adminFor(resource.data.instituteId) && sameInstituteUpdate());
      allow delete: if isSuperAdmin() || adminFor(resource.data.instituteId);
    }

    match /assignments/{assignmentId} {
      allow read: if sameInstitute(resource.data);
      allow create: if isSuperAdmin() || adminOrTeacherFor(request.resource.data.instituteId);
      allow update: if isSuperAdmin() ||
        (adminOrTeacherFor(resource.data.instituteId) && sameInstituteUpdate());
      allow delete: if isSuperAdmin() || adminOrTeacherFor(resource.data.instituteId);
    }

    match /courses/{courseId} {
      allow read: if isSuperAdmin() ||
        ((isAdmin() || isFaculty()) && sameInstitute(resource.data)) ||
        ((isStudent() || isParent()) && sameInstitute(resource.data) &&
          (resource.data.published == true || resource.data.status == 'published'));

      allow create: if isSuperAdmin() ||
        (adminOrTeacherFor(request.resource.data.instituteId) &&
          request.resource.data.instituteId is string &&
          request.resource.data.title is string);

      allow update: if isSuperAdmin() ||
        (adminOrTeacherFor(resource.data.instituteId) && sameInstituteUpdate());
      allow delete: if isSuperAdmin() || adminOrTeacherFor(resource.data.instituteId);

      match /modules/{moduleId} {
        allow read: if isSuperAdmin() ||
          ((isAdmin() || isFaculty()) && sameInstitute(get(/databases/$(database)/documents/courses/$(courseId)).data)) ||
          ((isStudent() || isParent()) &&
            sameInstitute(get(/databases/$(database)/documents/courses/$(courseId)).data) &&
            (get(/databases/$(database)/documents/courses/$(courseId)).data.published == true ||
              get(/databases/$(database)/documents/courses/$(courseId)).data.status == 'published'));
        allow create, update, delete: if isSuperAdmin() ||
          adminOrTeacherFor(get(/databases/$(database)/documents/courses/$(courseId)).data.instituteId);
      }
    }

    match /courseProgress/{progressId} {
      allow read: if isSuperAdmin() ||
        ((isAdmin() || isFaculty()) && sameInstitute(resource.data)) ||
        (signedIn() && sameInstitute(resource.data) && resource.data.userId == request.auth.uid);

      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        sameInstitute(request.resource.data) &&
        request.resource.data.courseId is string &&
        request.resource.data.lessonId is string;

      allow update: if signedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid &&
        sameInstituteUpdate() &&
        request.resource.data.courseId == resource.data.courseId &&
        request.resource.data.lessonId == resource.data.lessonId &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['positionSeconds', 'durationSeconds', 'completed', 'completedAt', 'notes', 'updatedAt']);

      allow delete: if isSuperAdmin() || adminFor(resource.data.instituteId);
    }

    match /grades/{gradeId} {
      allow read: if isSuperAdmin() ||
        ((isAdmin() || isTeacher()) && sameInstitute(resource.data)) ||
        studentOwnsGrade(resource.data) ||
        parentOwnsStudentData(resource.data);

      allow create: if isSuperAdmin() || adminOrTeacherFor(request.resource.data.instituteId);
      allow update: if isSuperAdmin() ||
        (adminOrTeacherFor(resource.data.instituteId) && sameInstituteUpdate());
      allow delete: if isSuperAdmin() || adminOrTeacherFor(resource.data.instituteId);
    }

    match /attendance/{attendanceId} {
      allow read: if isSuperAdmin() ||
        ((isAdmin() || isTeacher()) && sameInstitute(resource.data)) ||
        studentOwnsAttendance(resource.data) ||
        parentOwnsStudentData(resource.data);

      allow create: if isSuperAdmin() || adminOrTeacherFor(request.resource.data.instituteId);
      allow update: if isSuperAdmin() ||
        (adminOrTeacherFor(resource.data.instituteId) && sameInstituteUpdate());
      allow delete: if isSuperAdmin() || adminFor(resource.data.instituteId);
    }

    match /gallery/{imageId} {
      allow read: if sameInstitute(resource.data);
      allow create: if isSuperAdmin() || adminFor(request.resource.data.instituteId);
      allow update: if isSuperAdmin() ||
        (adminFor(resource.data.instituteId) && sameInstituteUpdate());
      allow delete: if isSuperAdmin() || adminFor(resource.data.instituteId);
    }

    match /pyqs/{paperId} {
      allow read: if sameInstitute(resource.data);
      allow create: if isSuperAdmin() || adminOrTeacherFor(request.resource.data.instituteId);
      allow update: if isSuperAdmin() ||
        (adminOrTeacherFor(resource.data.instituteId) && sameInstituteUpdate());
      allow delete: if isSuperAdmin() || adminOrTeacherFor(resource.data.instituteId);
    }

    match /paymentOrders/{orderId} {
      allow read: if isSuperAdmin() ||
        userOwnsInstituteDocument(resource.data) ||
        adminFor(resource.data.instituteId);
      allow write: if false;
    }

    match /feeStructures/{structureId} {
      allow read: if isSuperAdmin() || sameInstitute(resource.data);
      allow write: if false;
    }

    match /feeInvoices/{invoiceId} {
      allow read: if isSuperAdmin() ||
        adminFor(resource.data.instituteId) ||
        (isStudent() && sameInstitute(resource.data) && resource.data.studentUid == request.auth.uid) ||
        parentOwnsStudentData(resource.data);
      allow write: if false;
    }

    match /studentImportJobs/{jobId} {
      allow read: if isSuperAdmin() || adminFor(resource.data.instituteId);
      allow write: if false;
    }

    match /backgroundTasks/{taskId} {
      allow read, write: if false;
    }

    match /backgroundTaskDeadLetters/{taskId} {
      allow read, write: if false;
    }

    match /stripeWebhookEvents/{eventId} {
      allow read, write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isSuperAdmin() ||
        ((isAdmin() || isTeacher() || isStudent() || isParent() || isDriver()) && notificationVisible(resource.data));
      allow create: if isSuperAdmin() || adminOrTeacherFor(request.resource.data.instituteId);
      allow update: if isSuperAdmin() ||
        (adminFor(resource.data.instituteId) && sameInstituteUpdate()) ||
        ((isAdmin() || isTeacher() || isStudent() || isParent() || isDriver()) && sameInstitute(resource.data) && notificationReadReceiptOnly());
      allow delete: if isSuperAdmin() || adminFor(resource.data.instituteId);
    }

    match /payments/{paymentId} {
      allow read: if isSuperAdmin() ||
        userOwnsInstituteDocument(resource.data) ||
        adminFor(resource.data.instituteId);
      allow write: if false;
    }

    match /pushTokens/{userId} {
      allow read: if isSuperAdmin() ||
        request.auth.uid == userId ||
        adminFor(resource.data.instituteId);
      allow create: if signedIn() &&
        request.auth.uid == userId &&
        request.resource.data.uid == request.auth.uid &&
        sameInstitute(request.resource.data);
      allow update: if signedIn() &&
        request.auth.uid == userId &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.uid == request.auth.uid &&
        sameInstituteUpdate();
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /officeHourPolicies/{userId} {
      allow read: if isSuperAdmin() || sameInstitute(resource.data);
      allow write: if false;
    }

    match /conversations/{conversationId} {
      allow read: if isSuperAdmin() || conversationParticipant(resource.data);
      allow write: if false;
    }

    match /messages/{messageId} {
      allow read: if isSuperAdmin() ||
        (sameInstitute(resource.data) &&
          resource.data.keys().hasAny(['conversationId']) &&
          conversationParticipant(get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data));
      allow write: if false;
    }

    match /syllabi/{syllabusId} {
      allow read: if isSuperAdmin() || sameInstitute(resource.data);
      allow write: if false;
    }

    match /syllabusChunks/{chunkId} {
      allow read, write: if false;
    }

    match /teacherAbsences/{absenceId} {
      allow read: if isSuperAdmin() || ((isAdmin() || isFaculty()) && sameInstitute(resource.data));
      allow write: if false;
    }

    match /substituteAssignments/{assignmentId} {
      allow read: if isSuperAdmin() ||
        (isAdmin() && sameInstitute(resource.data)) ||
        (isFaculty() && sameInstitute(resource.data) && resource.data.substituteTeacherUid == request.auth.uid);
      allow write: if false;
    }

    match /systemState/{stateId} {
      allow read, write: if false;
    }

    match /academicYears/{academicYearId} {
      allow read: if isSuperAdmin() || sameInstitute(resource.data);
      allow create: if isSuperAdmin() || adminFor(request.resource.data.instituteId);
      allow update: if isSuperAdmin() ||
        (adminFor(resource.data.instituteId) && sameInstituteUpdate());
      allow delete: if isSuperAdmin() || adminFor(resource.data.instituteId);
    }

    match /standards/{standardId} {
      allow read: if isSuperAdmin() || sameInstitute(resource.data);
      allow create: if isSuperAdmin() || adminFor(request.resource.data.instituteId);
      allow update: if isSuperAdmin() ||
        (adminFor(resource.data.instituteId) && sameInstituteUpdate());
      allow delete: if isSuperAdmin() || adminFor(resource.data.instituteId);
    }

    match /classSections/{classSectionId} {
      allow read: if isSuperAdmin() || sameInstitute(resource.data);
      allow create: if isSuperAdmin() || adminFor(request.resource.data.instituteId);
      allow update: if isSuperAdmin() ||
        (adminFor(resource.data.instituteId) && sameInstituteUpdate());
      allow delete: if isSuperAdmin() || adminFor(resource.data.instituteId);
    }

    match /classTeacherAssignments/{assignmentId} {
      allow read: if isSuperAdmin() || sameInstitute(resource.data);
      allow create: if isSuperAdmin() || adminFor(request.resource.data.instituteId);
      allow update: if isSuperAdmin() ||
        (adminFor(resource.data.instituteId) && sameInstituteUpdate());
      allow delete: if isSuperAdmin() || adminFor(resource.data.instituteId);
    }

    match /dailyAttendance/{recordId} {
      allow read: if isSuperAdmin() || sameInstitute(resource.data);
      allow create: if isSuperAdmin() || adminOrTeacherFor(request.resource.data.instituteId);
      allow update: if isSuperAdmin() ||
        (adminOrTeacherFor(resource.data.instituteId) && sameInstituteUpdate());
      allow delete: if isSuperAdmin() || adminFor(resource.data.instituteId);
    }

    match /departments/{departmentId} {
      allow read: if isSuperAdmin() || sameInstitute(resource.data);
      allow create: if isSuperAdmin() || adminFor(request.resource.data.instituteId);
      allow update: if isSuperAdmin() ||
        (adminFor(resource.data.instituteId) && sameInstituteUpdate());
      allow delete: if isSuperAdmin() || adminFor(resource.data.instituteId);
    }

    match /semesters/{semesterId} {
      allow read: if isSuperAdmin() || sameInstitute(resource.data);
      allow create: if isSuperAdmin() || adminFor(request.resource.data.instituteId);
      allow update: if isSuperAdmin() ||
        (adminFor(resource.data.instituteId) && sameInstituteUpdate());
      allow delete: if isSuperAdmin() || adminFor(resource.data.instituteId);
    }

    match /courseCreditHours/{creditId} {
      allow read: if isSuperAdmin() || sameInstitute(resource.data);
      allow create: if isSuperAdmin() || adminFor(request.resource.data.instituteId);
      allow update: if isSuperAdmin() ||
        (adminFor(resource.data.instituteId) && sameInstituteUpdate());
      allow delete: if isSuperAdmin() || adminFor(resource.data.instituteId);
    }

    match /electiveRegistrations/{registrationId} {
      allow read: if isSuperAdmin() ||
        ((isAdmin() || isFaculty()) && sameInstitute(resource.data)) ||
        (isStudent() && sameInstitute(resource.data) && resource.data.studentUid == request.auth.uid);

      allow create: if isSuperAdmin() ||
        adminFor(request.resource.data.instituteId) ||
        (isStudent() &&
          sameInstitute(request.resource.data) &&
          request.resource.data.studentUid == request.auth.uid);

      allow update: if isSuperAdmin() ||
        (adminFor(resource.data.instituteId) && sameInstituteUpdate()) ||
        (isStudent() &&
          sameInstituteUpdate() &&
          resource.data.studentUid == request.auth.uid &&
          request.resource.data.studentUid == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'updatedBy']) &&
          request.resource.data.status == 'dropped');

      allow delete: if isSuperAdmin() || adminFor(resource.data.instituteId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
