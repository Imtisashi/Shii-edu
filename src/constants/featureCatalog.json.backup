  "features": [
    {
      "key": "institute_dashboard",
      "label": "Institute dashboard",
      "description": "Core dashboard and role workspace entry points.",
      "category": "Core"
    },
    {
      "key": "people",
      "label": "People and directory",
      "description": "Shared people directory used by student, staff, parent, driver, and faculty records.",
      "category": "Core"
    },
    {
      "key": "admin_management",
      "label": "Admin management",
      "description": "Institute administrator management and admin-only workflows.",
      "category": "Core"
    },
    {
      "key": "teacher_management",
      "label": "Teacher management",
      "description": "Teacher profiles, assignments, payroll visibility, and faculty administration.",
      "category": "Core"
    },
    {
      "key": "student_management",
      "label": "Student management",
      "description": "Student profiles, identifiers, classes, sections, and learner administration.",
      "category": "Core"
    },
    {
      "key": "parent_management",
      "label": "Parent management",
      "description": "Parent and guardian profiles, linked-student access, and parent support readiness.",
      "category": "Core"
    },
    {
      "key": "class_section_management",
      "label": "Class and section management",
      "description": "School classes, sections, and cohort organization.",
      "category": "Academics"
    },
    {
      "key": "subject_management",
      "label": "Subject management",
      "description": "Subject, department, and course assignment metadata.",
      "category": "Academics"
    },
    {
      "key": "attendance",
      "label": "Attendance",
      "description": "Daily attendance capture and attendance views.",
      "category": "Academics"
    },
    {
      "key": "routines",
      "label": "Timetable and calendar",
      "description": "Basic timetable, master schedules, holidays, and calendar events.",
      "category": "Academics"
    },
    {
      "key": "assignments",
      "label": "Assignments",
      "description": "Coursework, uploads, submissions, and teacher assignment flows.",
      "category": "Academics"
    },
    {
      "key": "grades",
      "label": "Grades",
      "description": "Marks, grade uploads, reports, and learner progress.",
      "category": "Academics"
    },
    {
      "key": "notices",
      "label": "Notices and announcements",
      "description": "Role-aware notices, alerts, broadcasts, and notifications.",
      "category": "Communication"
    },
    {
      "key": "messages",
      "label": "Messages",
      "description": "Role-scoped communication hub and conversations.",
      "category": "Communication"
    },
    {
      "key": "parent_support",
      "label": "Parent support desk",
      "description": "Assisted parent rollout, parent linking checks, and low-tech support exports.",
      "category": "School Operations"
    },
    {
      "key": "finance",
      "label": "Fees and ledger",
      "description": "Fee assignments, manual payments, dues, receipts, and payment metadata.",
      "category": "Operations"
    },
    {
      "key": "reports",
      "label": "Basic reports",
      "description": "Basic operational and academic report surfaces.",
      "category": "Reports"
    },
    {
      "key": "advanced_reports",
      "label": "Advanced reports",
      "description": "Deeper operator reports, exports, analytics, and review workflows.",
      "category": "Reports"
    },
    {
      "key": "bus_tracking",
      "label": "Bus tracking",
      "description": "Driver portal, assigned route visibility, and live fleet tracking surfaces.",
      "category": "Transport"
    },
    {
      "key": "courses",
      "label": "Courses",
      "description": "Course media, lessons, resources, and course playback.",
      "category": "Learning"
    },
    {
      "key": "media",
      "label": "Gallery and media",
      "description": "Gallery uploads, institute media, and scoped media storage.",
      "category": "Learning"
    },
    {
      "key": "pyq",
      "label": "PYQ library",
      "description": "Previous-year question paper uploads and student access.",
      "category": "Learning"
    },
    {
      "key": "ai_tools",
      "label": "AI tools",
      "description": "Syllabus tutor, smart compose, CSV mapping, and approved AI workflows.",
      "category": "AI"
    },
    {
      "key": "ai_agent",
      "label": "Max AI admin agent",
      "description": "Bounded natural-language admin reports, exports, and audit-logged operator assistance.",
      "category": "AI"
    },
    {
      "key": "ai_lesson_planner",
      "label": "AI Lesson Planner",
      "description": "AI-powered lesson planning and curriculum mapping.",
      "category": "AI"
    },
    {
      "key": "ai_automated_grading",
      "label": "Automated Grading",
      "description": "AI-assisted grading and feedback for assignments.",
      "category": "AI"
    },
    {
      "key": "ai_insights",
      "label": "AI-Powered Insights",
      "description": "AI-generated analytics and insights on student performance and engagement.",
      "category": "AI"
    },
    {
      "key": "advanced_analytics",
      "label": "Advanced Analytics Dashboard",
      "description": "Customizable dashboards for attendance trends, bus utilization, and performance analytics.",
      "category": "Analytics"
    },
    {
      "key": "white_labeling",
      "label": "White Labeling",
      "description": ability to remove EduHub branding and apply院徽 and custom themes.",
      "category": "Customization"
    },
    {
      "key": "custom_domain",
      "label": "Custom Domain",
      "description": "Use a custom domain name for the institute's portal.",
      "category": "Customization"
    },
    {
      "key": "custom_ssl",
      "label": "Custom SSL",
      "description": "Upload and use custom SSL certificates for custom domains.",
      "category": "Customization"
    },
    {
      "key": "branded_mobile_apps",
      "label": "Branded Mobile Apps",
      "description": "Custom-branded mobile apps for iOS and Android with institute logo and colors.",
      "category": "Customization"
    },
    {
      "key": "storage_quota",
      "label": "Storage Quota",
      "description": "Cloud storage allocation for documents, assets, and backups.",
      "category": "Resources"
    },
    {
      "key": "sms_notifications",
      "label": "SMS Notifications",
      "description": "Send SMS notifications via Twilio for attendance, fees, and announcements.",
      "category": "Communication"
    },
    {
      "key": "api_access",
      "label": "API Access",
      "description": "REST API access for third-party integrations (SIS, LMS, etc.).",
      "category": "Integration"
    },
    {
      "key": "marketplace",
      "label": "Marketplace Access",
      "description": "Access to EduHub Marketplace for educational content and tools (revenue share).",
      "category": "Marketplace"
    },
    {
      "key": "priority_support",
      "label": "Priority Support",
      "description": "Priority support with faster response times.",
      "category": "Support"
    },
    {
      "key": "dedicated_account_manager",
      "label": "Dedicated Account Manager",
      "description": "Dedicated account manager for enterprise customers.",
      "category": "Support"
    }
  ],
