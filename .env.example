# Optional for web production: leave empty to use same-origin Vercel /api routes.
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000
EXPO_PUBLIC_FIREBASE_API_KEY=replace_with_firebase_web_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=replace_with_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=replace_with_firebase_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=replace_with_project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace_with_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=replace_with_firebase_app_id
FIREBASE_PROJECT_ID=replace_with_firebase_project_id
FIREBASE_CLIENT_EMAIL=replace_with_service_account_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_with_private_key\n-----END PRIVATE KEY-----\n"
# Alternative to FIREBASE_CLIENT_EMAIL/FIREBASE_PRIVATE_KEY:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
APP_ORIGIN=http://localhost:19006,http://127.0.0.1:19006,https://shii-edu.vercel.app
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=replace_with_cloud_name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=replace_with_restricted_unsigned_preset
