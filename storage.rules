rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function profileExists() {
      return signedIn() && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function profile() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function role() {
      return profileExists() ? profile().role : null;
    }

    function isSuperAdminRole(value) {
      return value in ['superadmin', 'superAdmin', 'SuperAdmin', 'super_admin', 'super-admin', 'super admin'];
    }

    function isSuperAdmin() {
      return signedIn() && (
        isSuperAdminRole(role()) ||
        isSuperAdminRole(request.auth.token.role) ||
        isSuperAdminRole(request.auth.token.userRole) ||
        isSuperAdminRole(request.auth.token.user_role) ||
        request.auth.token.superadmin == true ||
        request.auth.token.superAdmin == true
      );
    }

    function isTenantMember(instituteId) {
      return isSuperAdmin() || (profileExists() && profile().instituteId == instituteId);
    }

    function canUploadInstitutionAsset(instituteId) {
      return isTenantMember(instituteId) &&
        (isSuperAdmin() || role() in ['admin', 'teacher', 'professor']);
    }

    function isAllowedUploadSize() {
      return request.resource != null && request.resource.size < 30 * 1024 * 1024;
    }

    match /uploads/institutions/{instituteId}/{allPaths=**} {
      allow read: if signedIn() && isTenantMember(instituteId);
      allow write: if signedIn() && canUploadInstitutionAsset(instituteId) && isAllowedUploadSize();
    }

    match /uploads/profile-pictures/{userId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && (request.auth.uid == userId || isSuperAdmin()) && isAllowedUploadSize();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
