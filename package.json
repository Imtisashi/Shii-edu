{
  "name": "shii-edu",
  "main": "index.js",
  "version": "1.0.0",
  "workspaces": [
    "apps/edu-hub-superadmin",
    "apps/edu-shii"
  ],
  "scripts": {
    "start": "expo start",
    "build": "expo export --platform web --output-dir web-build",
    "build:expo": "expo export --platform web --output-dir web-build",
    "build:ssr": "npm run build:expo && node ./scripts/sync-expo-web-to-next-public.js && node ./node_modules/next/dist/bin/next build --webpack",
    "dev:ssr": "node ./node_modules/next/dist/bin/next dev",
    "typecheck": "tsc --noEmit",
    "vercel:env:sync": "node ./scripts/sync-vercel-env.js",
    "deploy:vercel": "npm run typecheck && npm run build:ssr && npx vercel --prod --yes --non-interactive",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "superadmin:start": "npm --workspace edu-hub-superadmin run start",
    "institute:start": "npm --workspace edu-shii run start",
    "lint": "eslint src",
    "deploy:firebase:rules": "npx --yes firebase-tools@15.19.0 deploy --only firestore:rules --project edu-hub-1fce7 --non-interactive",
    "deploy:firebase:database-rules": "npx --yes firebase-tools@15.19.0 deploy --only database --project edu-hub-1fce7 --non-interactive"
  },
  "dependencies": {
    "@expo/metro-runtime": "56.0.13",
    "@expo/vector-icons": "15.1.1",
    "@lottiefiles/dotlottie-react": "0.19.4",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "7.16.2",
    "@react-navigation/drawer": "^7.10.3",
    "@react-navigation/elements": "2.9.19",
    "@react-navigation/native": "7.2.5",
    "@react-navigation/stack": "7.9.3",
    "@shopify/flash-list": "2.0.2",
    "@stripe/stripe-react-native": "0.64.0",
    "@supabase/supabase-js": "^2.107.0",
    "@vercel/functions": "^3.6.1",
    "base64-arraybuffer": "^1.0.2",
    "bootstrap": "^5.3.8",
    "expo": "56.0.8",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "56.0.16",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "56.0.18",
    "expo-device": "~56.0.4",
    "expo-document-picker": "56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-font": "56.0.5",
    "expo-haptics": "56.0.3",
    "expo-image": "56.0.9",
    "expo-image-picker": "56.0.15",
    "expo-linking": "56.0.13",
    "expo-local-authentication": "~56.0.4",
    "expo-location": "~56.0.15",
    "expo-notifications": "~56.0.15",
    "expo-print": "~56.0.3",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.15",
    "expo-splash-screen": "56.0.10",
    "expo-status-bar": "56.0.4",
    "expo-symbols": "56.0.5",
    "expo-system-ui": "56.0.5",
    "expo-task-manager": "^56.0.16",
    "expo-web-browser": "56.0.5",
    "firebase": "12.14.0",
    "firebase-admin": "13.10.0",
    "hls.js": "^1.6.16",
    "lottie-react-native": "7.3.8",
    "lucide-react": "^0.556.0",
    "motion": "^12.40.0",
    "next": "^16.0.7",
    "papaparse": "5.5.3",
    "pdf-parse": "^1.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-chart-kit": "6.12.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-maps": "1.27.2",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "0.21.2",
    "react-native-worklets": "0.8.3",
    "stripe": "^22.2.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/papaparse": "^5.5.2",
    "@types/react": "19.2.15",
    "ajv": "8.20.0",
    "ajv-keywords": "5.1.0",
    "eslint": "9.39.4",
    "eslint-config-expo": "56.0.4",
    "playwright": "^1.60.0",
    "typescript": "6.0.3"
  },
  "overrides": {
    "postcss": "8.5.10",
    "uuid": "11.1.1"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  }
}
