    "eslint-config-expo": "56.0.4",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.10",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.6.3"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "form-data": "4.0.6",
    "protobufjs": "7.6.4",
    "undici": "6.27.0",
