{
  "name": "shii-edu",
  "main": "index.js",
  "version": "1.0.0",
  "workspaces": [
    "apps/edu-hub-superadmin",
    "apps/edu-shii"
  ],
  "scripts": {
    "start": "expo start",
    "clean:web-build": "node -e \"const fs=require('fs');['web-build','public/_expo','public/assets','public/expo-index.html','public/metadata.json'].forEach((p)=>fs.rmSync(p,{recursive:true,force:true}))\"",
    "generate:pwa-icons": "node ./scripts/generate-pwa-icons.js",
    "build": "npm run clean:web-build && expo export --platform web --output-dir web-build",
    "build:expo": "npm run clean:web-build && expo export --platform web --output-dir web-build",
    "build:ssr": "npm run build:expo && node ./scripts/sync-expo-web-to-next-public.js && node ./node_modules/next/dist/bin/next build --webpack",
    "dev:ssr": "node ./node_modules/next/dist/bin/next dev",
    "analyze": "npm run build:expo && node ./scripts/sync-expo-web-to-next-public.js && ANALYZE=true node ./node_modules/next/dist/bin/next build --webpack",
    "typecheck": "tsc --noEmit",
    "vercel:env:sync": "node ./scripts/sync-vercel-env.js",
    "deploy:vercel": "npm run typecheck && npm run build:ssr && npx vercel --prod --yes --non-interactive",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "android:apk:driver": "node ./scripts/build-role-apk.js driver",
    "android:apk:institute": "node ./scripts/build-role-apk.js institute",
    "android:apk:parents": "node ./scripts/build-role-apk.js parents",
    "android:apk:superadmin": "node ./scripts/build-role-apk.js superadmin",
    "android:apk:roles": "node ./scripts/build-role-apk.js all",
    "desktop:superadmin": "powershell -ExecutionPolicy Bypass -File ./scripts/build-superadmin-desktop.ps1",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "superadmin:start": "npm --workspace edu-hub-superadmin run start",
    "institute:start": "npm --workspace edu-shii run start",
    "lint": "eslint src",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "deploy:firebase:rules": "npx --yes firebase-tools@15.19.0 deploy --only firestore:rules --project edu-hub-1fce7 --non-interactive",
    "deploy:firebase:database-rules": "npx --yes firebase-tools@15.19.0 deploy --only database --project edu-hub-1fce7 --non-interactive"
  },
  "dependencies": {
    "@expo/metro-runtime": "56.0.13",
